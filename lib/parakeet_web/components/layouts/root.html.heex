<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="Parakeet" suffix=" · Phoenix Framework">
      {assigns[:page_title]}
    </.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
    <script>
      (() => {
        const STORAGE = "phx:theme";
        const mq = window.matchMedia("(prefers-color-scheme: dark)");
        window.parakeetApplyTheme = function parakeetApplyTheme() {
          const raw = localStorage.getItem(STORAGE);
          const pref = raw === "light" || raw === "dark" || raw === "system" ? raw : "system";
          let effective;
          if (pref === "light") effective = "light";
          else if (pref === "dark") effective = "dark";
          else effective = mq.matches ? "dark" : "light";
          document.documentElement.setAttribute("data-theme", effective);
          document.documentElement.setAttribute("data-theme-pref", pref);
          window.dispatchEvent(new Event("parakeet-theme-applied"));
        };
        window.parakeetApplyTheme();
        mq.addEventListener("change", () => {
          if ((localStorage.getItem(STORAGE) || "system") === "system") {
            window.parakeetApplyTheme();
          }
        });
        window.addEventListener("storage", (e) => {
          if (e.key === STORAGE) window.parakeetApplyTheme();
        });
        window.addEventListener("phx:set-theme", (e) => {
          const btn = e.target && e.target.closest && e.target.closest("[data-phx-theme]");
          const theme = btn && btn.dataset && btn.dataset.phxTheme;
          if (theme !== "system" && theme !== "light" && theme !== "dark") return;
          if (theme === "system") localStorage.removeItem(STORAGE);
          else localStorage.setItem(STORAGE, theme);
          window.parakeetApplyTheme();
        });
      })();
    </script>
  </head>
  <body>
    {@inner_content}
  </body>
</html>
